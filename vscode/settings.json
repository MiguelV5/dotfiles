{
    // ====================== INIT ====================== //
    "telemetry.telemetryLevel": "off",
    "update.mode": "manual",
    "workbench.startupEditor": "none",
    "editor.mouseWheelZoom": true,
    "vsicons.dontShowNewVersionMessage": true,
    // ====================== EDIT & WORKSPACE ====================== //
    "editor.wordWrap": "on",
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.mouseWheelScrollSensitivity": 2,
    "output.smartScroll.enabled": false,
    "notebook.output.textLineLimit": 50,
    "workbench.layoutControl.enabled": false,
    "explorer.confirmDelete": false,
    "workbench.editor.enablePreview": false,
    "files.associations": {
        "*.asm": "sparc",
        "*.S": "asm-intel-x86-generic"
    },
    "workbench.editor.empty.hint": "hidden",
    "workbench.sideBar.location": "right",
    // ====================== VISUALS ====================== //
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "terminal.integrated.fontFamily": "MesloLGS Nerd Font",
    "workbench.colorTheme": "Dark Modern",
    "workbench.iconTheme": "vscode-icons",
    "editor.fontFamily": "'Fira Code', monospace,'Fira Mono'",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#131925",
        "titleBar.activeForeground": "#ffffff",
        "statusBar.background": "#131925",
        "statusBar.noFolderBackground": "#131925",
        "statusBar.debuggingBackground": "#131925",
        "activityBar.foreground": "#84a5fb",
        "activityBar.activeBorder": "#84a5fb",
        "activityBar.background": "#131925",
        "sideBar.background": "#131925",
        "tab.activeBackground": "#0f111a",
        "editor.background": "#0f111a",
        "editorGroupHeader.tabsBackground": "#131925",
        "tab.border": "#465785",
        "tab.activeBorderTop": "#84a5fb",
        "tab.inactiveBackground": "#172235",
        "tab.inactiveForeground": "#ffffff",
        "tab.activeForeground": "#ffffff",
        "button.background": "#84a5fb",
        "button.foreground": "#000000",
        "button.hoverBackground": "#738cca",
        "inputOption.activeBorder": "#738cca",
        "inputOption.activeBackground": "#5a6d9c",
        "inputOption.activeForeground": "#ffffff",
    },
    "editor.tokenColorCustomizations": {
        "comments": "#6C736C"
    },
    "editor.fontLigatures": true,
    "window.titleBarStyle": "custom",
    "explorer.confirmDragAndDrop": false,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "on",
    "workbench.list.smoothScrolling": false,
    "editor.smoothScrolling": true,
    "editor.fontSize": 17,
    // Really useful for detecting weird unicode characters in the code
    "editor.unicodeHighlight.includeComments": true,
    // ====================== EXTENSIONS CFG & MISC ====================== //
    // GITLENS //
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "editor.inlineSuggest.enabled": true,
    // PY FORMATTER //
    "[python]": {
        "editor.defaultFormatter": "ms-python.flake8"
    },
    "black-formatter.args": [
        "--line-length",
        "110",
        "--skip-string-normalization",
        "--skip-magic-trailing-comma",
    ],
    "flake8.args": [
        "--max-line-length=128",
        "--ignore=E501,E231,E402,F841,F401,E302,E305,E117,E303,W293,W292,W291,W391,W605",
    ],
    // GIT //
    "git.openRepositoryInParentFolders": "never",
    "terminal.integrated.env.linux": {},
    // WEB-RELATED FORMATTERS //
    "svelte.enable-ts-plugin": true,
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[javascript]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[html]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "update.showReleaseNotes": false,
    "github.copilot.editor.enableAutoCompletions": true,
    "extensions.ignoreRecommendations": true,
    "chat.editing.alwaysSaveWithGeneratedChanges": true,
    "github.copilot.advanced": {
        "authPermissions": "minimal"
    },
    "editor.formatOnSave": true,
    "azureTerraform.survey": {
        "surveyPromptDate": "2025-08-21T21:03:58.542Z",
        "surveyPromptIgnoredCount": 1
    },
}